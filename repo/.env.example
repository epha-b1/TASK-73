NODE_ENV=development
API_PORT=3000
DATABASE_URL=postgres://localtrade:localtrade@postgres:5432/localtrade
JWT_SECRET=change-me-please-with-32+chars
SIGNED_URL_SECRET=change-me-please-with-32+chars
ENCRYPTION_KEY_HEX=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
MEDIA_ROOT_PATH=/var/localtrade/media
CHUNK_ROOT_PATH=/var/localtrade/chunks
RATE_LIMIT_PER_MIN=60
NONCE_WINDOW_SEC=300
CORS_ALLOWED_ORIGINS=http://localhost:4200
SIGNED_URL_TTL_MIN=15
WEBHOOK_ALLOWED_CIDRS=127.0.0.1/32,10.0.0.0/8,192.168.0.0/16

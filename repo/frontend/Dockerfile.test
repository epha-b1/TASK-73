FROM node:20-bookworm-slim
WORKDIR /app
COPY package.json package-lock.json angular.json tsconfig.json tsconfig.app.json tsconfig.spec.json vitest.config.ts proxy.conf.json ngsw-config.json ./
RUN set -eu; \
    npm config set fetch-retries 5; \
    npm config set fetch-retry-mintimeout 20000; \
    npm config set fetch-retry-maxtimeout 120000; \
    for i in 1 2 3; do \
      rm -rf node_modules; \
      npm ci --no-audit --no-fund --include=dev --loglevel=error || true; \
      if [ -x node_modules/.bin/ng ]; then break; fi; \
      sleep 5; \
    done; \
    test -x node_modules/.bin/ng
COPY src ./src
COPY public ./public
CMD ["sh", "-c", "npm test -- --watch=false && npm run build"]
